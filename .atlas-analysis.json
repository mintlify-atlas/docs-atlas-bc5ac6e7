  "keyFeatures": [
    "Cross-platform support (Android, iOS, Windows, macOS, Linux, WebAssembly, and more)",
    "Fully-asynchronous, non-blocking request/response model",
    "JSON interface usable from any language that can call C functions",
    "Native C++, Java (JNI), and .NET (C++/CLI/CX) bindings",
    "End-to-end encrypted local data storage with user-provided encryption key",
    "Consistent and ordered update delivery with reliable reconnection",
    "Full Telegram API coverage including messages, chats, files, calls, and bots"
  ],
